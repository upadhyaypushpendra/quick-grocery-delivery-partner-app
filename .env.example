# Delivery Partner Frontend environment variables (.env.local)
# Copy this file to dp-frontend/.env.local for local development overrides

# API URL (proxied by Vite dev server)
VITE_API_URL=/api

# Enable debug logging
VITE_DEBUG=false

# Geolocation settings
VITE_LOCATION_UPDATE_INTERVAL_SECONDS=30
VITE_LOCATION_TIMEOUT_SECONDS=10
VITE_GEOLOCATION_ENABLED=true
